{
  "manifest_version": 3,
  "name": "dydownload Cookie Helper",
  "version": "1.0.0",
  "description": "自动抓取抖音 Cookie 并传递给 dydownload CLI 下载工具",
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.douyin.com/*",
    "*://*.iesdouyin.com/*",
    "*://*.douyinvod.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "dydownload - 获取 Cookie"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
